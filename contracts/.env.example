# Copy to .env and fill in. NEVER commit a real private key or API token.
# Foundry auto-loads .env for `forge script`; .env is git-ignored.

# --- RPC endpoints (referenced by foundry.toml [rpc_endpoints]) ---
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_RPC=https://mainnet.base.org

# --- Deployer (testnet only; use a throwaway key funded with Sepolia ETH) ---
# Pass to forge via --private-key "$PRIVATE_KEY" (or use --account/keystore).
PRIVATE_KEY=

# --- Contract verification on Basescan (optional) ---
BASESCAN_API_KEY=

# --- Mainnet deploy (Deploy.s.sol) ---
NIKO_TOKEN=0x422273666D77F504E30E2573c063c7c50CCE8453
POOL_OWNER=
